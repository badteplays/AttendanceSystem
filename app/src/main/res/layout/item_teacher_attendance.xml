<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:paddingVertical="9dp">

        <TextView
            android:id="@+id/textAvatarInitials"
            android:layout_width="33dp"
            android:layout_height="33dp"
            android:gravity="center"
            android:text="MA"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textStudentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Student name"
                android:textColor="@color/teacher_ds_text_primary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/textSection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="2021-00142"
                android:textColor="@color/teacher_ds_text_secondary"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/textTimeTaken"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="9dp"
            android:paddingVertical="3dp"
            android:text="Present"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/buttonRemove"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_teacher_menu_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="⋮"
            android:textColor="@color/teacher_ds_text_muted"
            android:textSize="14sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="14dp"
        android:background="@color/teacher_ds_border_default" />
</LinearLayout>
