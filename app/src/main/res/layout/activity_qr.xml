<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/teacher_ds_page_bg"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/qrHeaderBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_teacher_header_shell"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingTop="10dp"
        android:paddingBottom="16dp"
        android:fitsSystemWindows="true">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_teacher_notif_button"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@android:color/white"
            android:clickable="true"
            android:focusable="true" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Attendance QR"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/txtHeaderSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan to mark attendance"
                android:textColor="@color/teacher_ds_on_dark_muted"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="24dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/qrCodeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/teacher_ds_card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <FrameLayout
                        android:layout_width="240dp"
                        android:layout_height="240dp"
                        android:background="@drawable/bg_teacher_qr_thumbnail"
                        android:padding="12dp">

                        <ImageView
                            android:id="@+id/qrCodeImage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerInside"
                            android:contentDescription="QR Code" />

                        <ProgressBar
                            android:id="@+id/progressBar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:visibility="gone" />
                    </FrameLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/expirationCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/teacher_ds_card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <View
                        android:layout_width="6dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_teacher_live_badge"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="QR code expires in"
                            android:textColor="@color/teacher_ds_text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/txtExpiration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="00:00"
                            android:textColor="@color/teacher_ds_status_present_accent"
                            android:textSize="22sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRenewQR"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Renew QR"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    app:cornerRadius="12dp"
                    app:backgroundTint="@color/teacher_ds_primary_dark"
                    app:icon="@drawable/ic_refresh"
                    app:iconTint="@android:color/white"
                    app:iconPadding="8dp"
                    app:iconSize="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSetExpiration"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Set timer"
                    android:textAllCaps="false"
                    android:textColor="@color/teacher_ds_primary_dark"
                    android:textSize="13sp"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/teacher_ds_primary_light"
                    app:strokeWidth="1dp"
                    app:icon="@drawable/ic_hours"
                    app:iconTint="@color/teacher_ds_primary_dark"
                    app:iconPadding="8dp"
                    app:iconSize="18dp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
