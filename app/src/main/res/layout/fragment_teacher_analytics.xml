<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/teacher_ds_page_bg">

    <LinearLayout
        android:id="@+id/headerShell"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_teacher_header_shell"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="18dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp">

                <TextView
                    android:id="@+id/textInitials"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_teacher_avatar_header"
                    android:gravity="center"
                    android:text="TC"
                    android:textColor="@android:color/white"
                    android:textSize="13sp" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Analytics"
                    android:textColor="@color/teacher_ds_on_dark_muted"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/textName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Teacher"
                    android:textColor="@android:color/white"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Attendance reports"
                    android:textColor="@color/teacher_ds_on_dark_muted"
                    android:textSize="10sp" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_teacher_day_tab_container"
            android:orientation="horizontal"
            android:padding="3dp">

            <TextView
                android:id="@+id/pill7Days"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="7 days"
                android:textSize="9sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/pill4Weeks"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="4 weeks"
                android:textSize="9sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/pill12Weeks"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="12 weeks"
                android:textSize="9sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/pillYear"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Year"
                android:textSize="9sp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/headerShell"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnFilterSubject"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/teacher_ds_card_bg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Subject"
                            android:textColor="@color/teacher_ds_text_secondary"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/filterSubjectValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="All subjects"
                            android:textColor="@color/teacher_ds_text_primary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnFilterSection"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/teacher_ds_card_bg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Section"
                            android:textColor="@color/teacher_ds_text_secondary"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/filterSectionValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="All sections"
                            android:textColor="@color/teacher_ds_text_primary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/teacher_ds_status_present_bg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="11dp">

                        <TextView
                            android:id="@+id/statSessions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/teacher_ds_status_present_text"
                            android:textSize="20sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sessions"
                            android:textColor="@color/teacher_ds_status_present_accent"
                            android:textSize="9sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/teacher_ds_status_absent_bg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="11dp">

                        <TextView
                            android:id="@+id/statStudents"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/teacher_ds_status_absent_text"
                            android:textSize="20sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Students"
                            android:textColor="@color/teacher_ds_status_absent_accent"
                            android:textSize="9sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/teacher_ds_status_late_bg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="11dp">

                        <TextView
                            android:id="@+id/statAvgRate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textColor="@color/teacher_ds_status_late_text"
                            android:textSize="20sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Avg rate"
                            android:textColor="@color/teacher_ds_status_late_accent"
                            android:textSize="9sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/teacher_ds_card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Overview"
                        android:textColor="@color/teacher_ds_primary_dark"
                        android:textSize="13sp"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <FrameLayout
                            android:layout_width="88dp"
                            android:layout_height="88dp">

                            <com.google.android.material.progressindicator.CircularProgressIndicator
                                android:id="@+id/ringChart"
                                android:layout_width="88dp"
                                android:layout_height="88dp"
                                android:layout_gravity="center"
                                app:indicatorSize="88dp"
                                app:trackThickness="9dp"
                                app:trackColor="@color/teacher_ds_border_medium"
                                app:indicatorColor="@color/teacher_ds_status_present_accent"
                                android:progress="0"
                                android:max="100" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/ringPct"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0%"
                                    android:textColor="@color/teacher_ds_text_primary"
                                    android:textSize="16sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Attendance"
                                    android:textColor="@color/teacher_ds_text_secondary"
                                    android:textSize="8sp" />
                            </LinearLayout>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView android:id="@+id/legendOnTime" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="● On time: 0" android:textColor="@color/teacher_ds_text_secondary" android:textSize="10sp" android:layout_marginBottom="6dp" />
                            <TextView android:id="@+id/legendAbsent" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="● Absences: 0" android:textColor="@color/teacher_ds_text_secondary" android:textSize="10sp" android:layout_marginBottom="6dp" />
                            <TextView android:id="@+id/legendLate" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="● Late: 0" android:textColor="@color/teacher_ds_text_secondary" android:textSize="10sp" android:layout_marginBottom="6dp" />
                            <TextView android:id="@+id/legendHours" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="● Hours logged: 0" android:textColor="@color/teacher_ds_text_secondary" android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/teacher_ds_border_default" />

                    <LinearLayout android:id="@+id/metricTotalClasses" android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:gravity="center_vertical" android:orientation="horizontal" android:paddingVertical="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Total classes" android:textColor="@color/teacher_ds_text_secondary" android:textSize="11sp" />
                        <TextView android:id="@+id/totalClassesText" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="@color/teacher_ds_text_primary" android:textSize="12sp" />
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/teacher_ds_border_default" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:gravity="center_vertical" android:orientation="horizontal" android:paddingVertical="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Total students" android:textColor="@color/teacher_ds_text_secondary" android:textSize="11sp" />
                        <TextView android:id="@+id/totalStudentsText" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="@color/teacher_ds_text_primary" android:textSize="12sp" />
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/teacher_ds_border_default" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:gravity="center_vertical" android:orientation="horizontal" android:paddingVertical="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Attendance rate" android:textColor="@color/teacher_ds_text_secondary" android:textSize="11sp" />
                        <TextView android:id="@+id/attendanceRateText" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0%" android:textColor="@color/teacher_ds_status_present_text" android:textSize="12sp" />
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/teacher_ds_border_default" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:gravity="center_vertical" android:orientation="horizontal" android:paddingVertical="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Punctuality rate" android:textColor="@color/teacher_ds_text_secondary" android:textSize="11sp" />
                        <TextView android:id="@+id/punctualityRateText" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0%" android:textColor="@color/teacher_ds_status_late_text" android:textSize="12sp" />
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/teacher_ds_border_default" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:gravity="center_vertical" android:orientation="horizontal" android:paddingVertical="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Best performing" android:textColor="@color/teacher_ds_text_secondary" android:textSize="11sp" />
                        <TextView android:id="@+id/bestPerformingClassText" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="N/A" android:textColor="#185FA5" android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/teacher_ds_card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monthly breakdown"
                        android:textColor="@color/teacher_ds_primary_dark"
                        android:textSize="13sp"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:id="@+id/barChartContainer"
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:gravity="bottom"
                        android:orientation="horizontal" />

                    <LinearLayout
                        android:id="@+id/barLabelContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="horizontal" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/teacher_ds_card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Class breakdown"
                        android:textColor="@color/teacher_ds_primary_dark"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp" />

                    <LinearLayout
                        android:id="@+id/classBreakdownContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
