// Firestore Security Rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isAuthenticated() {
      return request.auth != null;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function isTeacher() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (
               userDoc().data.isTeacher == true ||
               userDoc().data.role == 'teacher' ||
               userDoc().data.role == 'Teacher' ||
               userDoc().data.role == 'TEACHER'
             );
    }
    function isStudent() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (
               userDoc().data.isStudent == true ||
               userDoc().data.role == 'student' ||
               userDoc().data.role == 'Student' ||
               userDoc().data.role == 'STUDENT'
             );
    }

    function teacherOwnsSchedule(scheduleId) {
      return scheduleId != null &&
        exists(/databases/$(database)/documents/schedules/$(scheduleId)) &&
        get(/databases/$(database)/documents/schedules/$(scheduleId)).data.teacherId == request.auth.uid;
    }

    function teacherCanAccessFlatAttendance() {
      return isTeacher() && (
        resource.data.teacherId == request.auth.uid ||
        teacherOwnsSchedule(resource.data.scheduleId)
      );
    }

    function teacherCanUpdateFlatAttendanceDoc() {
      return isTeacher() && (
        teacherCanAccessFlatAttendance() ||
        (
          request.resource.data.teacherId == request.auth.uid &&
          teacherOwnsSchedule(request.resource.data.scheduleId)
        )
      );
    }

    match /students/{studentId} {
      allow read: if isStudent() && request.auth.uid == studentId;
      allow write: if isTeacher();
    }

    match /attendance_sessions/{sessionId} {
      allow write: if isTeacher();
      allow read: if isAuthenticated();
    }

    match /schedules/{scheduleId} {
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
      allow read, update, delete: if isTeacher() && resource.data.teacherId == request.auth.uid;
      allow read: if isStudent();

      match /attendance/{attendanceId} {
        allow create: if isTeacher();
        allow read: if (isTeacher() && resource.data.teacherId == request.auth.uid)
                    || (isStudent() && resource.data.studentId == request.auth.uid);
        allow update, delete: if isTeacher() && resource.data.teacherId == request.auth.uid;
      }
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isTeacher());
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /attendance/{attendanceId} {
      allow create: if isTeacher()
        || (isAuthenticated()
          && request.resource.data.userId == request.auth.uid
          && exists(/databases/$(database)/documents/attendance_sessions/$(request.resource.data.sessionId)));

      allow read: if isAuthenticated();

      allow update: if teacherCanUpdateFlatAttendanceDoc();
      allow delete: if teacherCanAccessFlatAttendance();
    }

    match /archived_attendance/{attendanceId} {
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
      allow read: if isAuthenticated();
      allow update: if teacherCanUpdateFlatAttendanceDoc();
      allow delete: if teacherCanAccessFlatAttendance();
    }

    match /routines/{routineId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
